{
  "name": "cosyhotels",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "ship": "bash scripts/git-ship.sh",
    "backfill:images": "curl -sS -X POST http://localhost:3000/api/admin/backfill-images || true",
    "ensure:featured": "curl -sS http://localhost:3000/api/cron/ensure-featured || true",
    "scrape:cosyhotels": "node scripts/scrape-cosyhotels.mjs",
    "model:high": "bash scripts/set-model.sh gpt-5",
    "model:fast": "bash scripts/set-model.sh o4-mini",
    "model:balanced": "bash scripts/set-model.sh gpt-4o",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.57.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "leaflet": "^1.9.4",
    "next": "^15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.3",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.47.2",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "playwright": "^1.55.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
