# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local data backups + throwaway debug scripts
scripts/backups/
scripts/_*.mjs

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# transient in-session scoring batch (downloaded photos + results)
scripts/_score_batch/
local/

# Playwright MCP browser-test artifacts
.playwright-mcp/
